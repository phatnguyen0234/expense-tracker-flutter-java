# Mobile App Environment Configuration
# Copy to .env and fill in your values

# API Configuration
API_BASE_URL=http://localhost:8080/api/v1
API_TIMEOUT_SECONDS=30

# Environment
ENVIRONMENT=development

# Feature Flags
ENABLE_DEBUGGING=true
ENABLE_LOGGING=true

# Notes:
# - For production, use API_BASE_URL pointing to your production server
# - Change ENABLE_DEBUGGING and ENABLE_LOGGING to false in production
# - API_TIMEOUT_SECONDS: Adjust based on your network conditions

